name: PR Test

on:
  pull_request:
    types: [labeled, synchronize]
  workflow_dispatch:

concurrency:
  group: pr-test-${{ github.event.pull_request.number || github.run_id }}
  cancel-in-progress: true

permissions:
  pull-requests: write
  contents: read

jobs:
  prepare:
    runs-on: ubuntu-latest
    outputs:
      head_sha: ${{ github.event.pull_request.head.sha }}
<% for name in model_families %>
      has_<< name >>: ${{ steps.detect.outputs.has_<< name >> }}
<%- endfor %>

    steps:
      - name: Detect changed files
        id: detect
        uses: actions/github-script@v7
        with:
          script: |
            const files = await github.paginate(github.rest.pulls.listFiles, {
              owner: context.repo.owner,
              repo: context.repo.repo,
              pull_number: context.payload.pull_request.number,
              per_page: 100
            });
            const filenames = files.map(f => f.filename);
<% for name, config in model_families.items() %>
            const has_<< name >> = filenames.some(f =>
              << config.src_dirs | tojson >>.some(d => f.startsWith(d))<% if config.exclude_dirs %> &&
              !<< config.exclude_dirs | tojson >>.some(d => f.startsWith(d))<% endif %>
            );
            core.setOutput('has_<< name >>', has_<< name >>);
<% endfor %>

      - name: Add labels to PR
        if: github.event.action == 'synchronize'
        continue-on-error: true
        uses: actions/github-script@v7
        with:
          script: |
            const ciLabels = [];
<% for name, config in model_families.items() %>
            if ('${{ steps.detect.outputs.has_<< name >> }}' === 'true')
              ciLabels.push('<< config.label >>');
<% endfor %>
            if (ciLabels.length > 0) {
              await github.rest.issues.addLabels({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.payload.pull_request.number,
                labels: ciLabels
              });
            }
<% for job_name, config in test_jobs.items() %>

  << job_name >>:
    name: "<% if config.device == 'cuda' %>NVIDIA<% else %>CPU<% endif %> / << job_name | replace('-' ~ config.device, '') >> (${{ matrix.model }})"
    needs: prepare
    if: >-
      needs.prepare.outputs.has_<< config.family >> == 'true'
      || (github.event.action == 'labeled' && github.event.label.name == '<< model_families[config.family].label >>')
    runs-on: [self-hosted]
    strategy:
      fail-fast: false
      matrix:
        model: << config.models | tojson >>
    env:
      HF_HOME: /media/hdddisk/.cache/huggingface
    steps:
      - uses: actions/checkout@v4
        with:
          ref: ${{ needs.prepare.outputs.head_sha }}

      - name: Install uv
        uses: astral-sh/setup-uv@v6

      - name: Install dependencies
        run: uv sync --extra test

      - name: Download checkpoint
        run: |
          persistent="/media/hdddisk/huggingface/${{ matrix.model }}"
          if [ ! -f "$persistent/config.json" ]; then
            uv run hf download Qwen/${{ matrix.model }} --local-dir "$persistent"
          fi
          mkdir -p checkpoints
          ln -sfn "$persistent" checkpoints/${{ matrix.model }}

      - name: Run tests
        run: uv run pytest << config.test_file >> -m slow -v -s --model ${{ matrix.model }} --device << config.device >>
<% endfor %>
