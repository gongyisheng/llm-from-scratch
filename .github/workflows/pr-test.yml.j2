<%- set model_families = {
    'qwen3': {
        'label': 'run-ci-qwen3',
        'src_dirs': ['qwen3/', 'tests/qwen3/'],
        'exclude_dirs': ['qwen3_moe/', 'tests/qwen3_moe/'],
    },
    'qwen3_moe': {
        'label': 'run-ci-qwen3-moe',
        'src_dirs': ['qwen3_moe/', 'tests/qwen3_moe/'],
        'exclude_dirs': [],
    },
} -%>

<%- set test_jobs = {
    'knowledge-qwen3-cpu': {
        'family': 'qwen3',
        'device': 'cpu',
        'test_file': 'tests/qwen3/test_knowledge.py',
        'models': ['Qwen3-0.6B', 'Qwen3-1.7B', 'Qwen3-4B', 'Qwen3-8B', 'Qwen3-14B', 'Qwen3-32B'],
    },
    'knowledge-qwen3-cuda': {
        'family': 'qwen3',
        'device': 'cuda',
        'test_file': 'tests/qwen3/test_knowledge.py',
        'models': ['Qwen3-0.6B', 'Qwen3-1.7B', 'Qwen3-4B'],
    },
    'accuracy-qwen3-cpu': {
        'family': 'qwen3',
        'device': 'cpu',
        'test_file': 'tests/qwen3/test_accuracy.py',
        'models': ['Qwen3-0.6B', 'Qwen3-1.7B', 'Qwen3-4B', 'Qwen3-8B', 'Qwen3-14B', 'Qwen3-32B'],
    },
    'accuracy-qwen3-cuda': {
        'family': 'qwen3',
        'device': 'cuda',
        'test_file': 'tests/qwen3/test_accuracy.py',
        'models': ['Qwen3-0.6B', 'Qwen3-1.7B', 'Qwen3-4B'],
    },
    'knowledge-qwen3-moe-cpu': {
        'family': 'qwen3_moe',
        'device': 'cpu',
        'test_file': 'tests/qwen3_moe/test_knowledge.py',
        'models': ['Qwen3-30B-A3B'],
    },
    'accuracy-qwen3-moe-cpu': {
        'family': 'qwen3_moe',
